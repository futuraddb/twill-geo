{
  "name": "futuraddb/twill-geo",
  "description": "This package allows you to easily manage Geo Structured Data (JSON-LD) for your Twill models.",
  "homepage": "futura.si",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0",
    "area17/twill": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "futuraddb\\TwillGeo\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "futuraddb\\TwillGeo\\TwillGeoServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
